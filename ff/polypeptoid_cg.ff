[ macros ]
protein_resnames "GLY|ALA|CYS|VAL|LEU|ILE|MET|PRO|HYP|ASN|GLN|ASP|ASPP|ASH|GLU|GLUP|GLH|THR|SER|LYS|LSN|LYN|ARG|HSE|HIS|HSD|HSP|HID|HIP|HIE|PHE|TYR|TRP|ALAp|CYSd|ASPd|GLUd|ILEp|LEUp|METd|ASNp|SERp|THRp|VALp|GLNp|LYSp|ARGp|HSDp|PHEp|TYRp|TRPp|NAEk"

protein_resnames_BBS_1  "ILEp|METd|VALp"
protein_resnames_BBS_2  "ASPd|PHEp|TRPp|TYRp"
protein_resnames_BBS_3  "CYSd|GLUd|GLNp|THRp|NAEk"
protein_resnames_BBS_4  "LYSp|LEUp|ASNp|ARGp"
protein_resnames_BBS_5  "ALAp|HSDp|SERp"

protein_resnames_improper_ASPd "ASPd"
protein_resnames_improper_GLUd "GLUd"
protein_resnames_improper_NAEk "NAEk"

prot_default_bb_type P2
stiff_fc 1000000


;;;ALAp; peptoid version of alanine (sarcosine)

[ moleculetype ]
; molname       nrexcl
   ALAp           3

[ atoms ]
; id type resnr residu atom cgnr   charge
 1   SP2  1     ALAp     BB     1      0    
 2   TC3  1     ALAp     SC1    2      0    
 
 [ constraints ]
;  i     j   funct   length  
  BB   SC1    1       0.255

[ bonds ]
;  i     j   funct   length   force.c.
  BB   SC1    1      0.255   14792.67


