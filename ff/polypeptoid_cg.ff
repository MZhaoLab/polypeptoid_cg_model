3   TC5                       1     PHEp     SC2    3    0    ; configuration, mimicking
4   TC5                       1     PHEp     SC3    4    0    ; ring structure

[bonds]
;  i     j   funct   length  force.c.
  BB   SC1    1       0.342     7415.82 	
;  i     j   funct   length  
 SC1   SC2    1       0.340  $stiff_fc
 SC1   SC3    1       0.340  $stiff_fc
 SC2   SC3    1       0.290  $stiff_fc

[constraints]
;  i     j   funct   length  
 SC1   SC2    1       0.340
 SC1   SC3    1       0.340
 SC2   SC3    1       0.290

[angles]
;  i     j    k     funct   angle  force.c.
  BB   SC1  SC2        2   120.000   50.0  
  BB   SC1  SC3        2   120.000   50.0
  
[exclusions]
; We do not want non-bounded interactions within the residue.
BB SC1 SC2 SC3
SC1 SC2 SC3
SC2 SC3


;;;TYRp; peptoid residue original tyrosine

[ moleculetype ]
; molname       nrexcl
   TYRp           3

[ atoms ]
;id type resnr residu atom cgnr   charge
1   $prot_default_bb_type     1     TYRp     BB     1    0
2   TC4                       1     TYRp     SC1    2    0  
3   TC5                       1     TYRp     SC2    3    0 
4   TC5                       1     TYRp     SC3    4    0  
5   TN6                       1     TYRp     SC4    5    0

[bonds]
;  i     j   funct   length  force.c.
  BB   SC1    1       0.289    11655.32 	
;  i     j   funct   length  
 SC1   SC2    1       0.300  $stiff_fc
 SC1   SC3    1       0.300  $stiff_fc
 SC2   SC4    1       0.285  $stiff_fc
 SC3   SC4    1       0.285  $stiff_fc
 SC2   SC3    1       0.300  $stiff_fc
 
[constraints]
;  i     j   funct   length  
 SC1   SC2    1       0.300
 SC1   SC3    1       0.300
 SC2   SC4    1       0.285
 SC3   SC4    1       0.285
 SC2   SC3    1       0.300

 [angles]
;  i     j    k     funct   angle  force.c.
   BB   SC1  SC2       2   120.000   60.0  
   BB   SC1  SC3       2   120.000   60.0 

[dihedrals]
;  i     j    k    l   funct   angle  force.c.
 SC4   SC2  SC3  SC1       2    180.0    50.0     ; to prevent backflipping of ring

[exclusions]
; We do not want non-bounded interactions within the residue.
BB SC1 SC2 SC3 SC4
SC1 SC2 SC3 SC4
SC2 SC3 SC4
SC3 SC4


;;;TRPp; peptoid residue original tryptophan

[ moleculetype ]
; molname       nrexcl
   TRPp           3

[ atoms ]
;id type resnr residu atom cgnr   charge
1   $prot_default_bb_type       1     TRPp     BB     1    0
2   TC4                         1     TRPp     SC1    2    0       36
3   TN6d                        1     TRPp     SC2    3    0       36
4   TC5                         1     TRPp     SC3    4    0        0
5   TC5                         1     TRPp     SC4    5    0       36
6   TC5                         1     TRPp     SC5    6    0       36

[ bonds ]
;  i     j   funct   length  force.c.
  BB   SC1    1       0.297     9430.50 	
;  i     j   funct   length  
 SC1   SC2    1       0.335  $stiff_fc
 SC2   SC5    1       0.412  $stiff_fc
 SC4   SC5    1       0.293  $stiff_fc
 SC1   SC4    1       0.404  $stiff_fc
 SC2   SC4    1       0.470  $stiff_fc

[ constraints ]
;  i     j   funct   length  
 SC1   SC2    1       0.335
 SC2   SC5    1       0.412
 SC4   SC5    1       0.293
 SC1   SC4    1       0.404
 SC2   SC4    1       0.470

[ angles ]
;  i     j    k     funct   angle  force.c.
  BB   SC1  SC2       2   120.000   60.0 
  BB   SC1  SC4       2   130.000    60.0  

[ dihedrals ]
;  i     j    k    l   funct   angle  force.c.
 SC5   SC4  SC2  SC1       2   180.0    100.0

[ virtual_sitesn ]
SC3 SC5 SC4 SC2 SC1 -- 2

[exclusions]
; We do not want non-bounded interactions within the residue.
BB SC1 SC2 SC3 SC4 SC5
SC1 SC2 SC3 SC4 SC5
SC2 SC3 SC4 SC5
SC3 SC4 SC5
SC4 SC5




;;;Links

;;;BOND
[ link ]
resname $protein_resnames
[ bonds ]
BB +BB 1 0.310 11207.15 {"comment": "BB-BB"}

;;;DIHEDRAL
[ link ]
resname $protein_resnames
[ dihedrals ]
-BB BB +BB ++BB 3  1.010 0.213 1.638 6.600 0.363 -4.534 {"comment": "BBBB"}

[ link ]
resname $protein_resnames
[ dihedrals ]
SC1 BB +BB +SC1 3  0.996 -3.197 1.810 2.426 1.252 -0.088 {"comment": "SBBS"}

[ link ]
resname $protein_resnames
[ dihedrals ]
BB +BB ++BB ++SC1 3  1.893 -4.783 3.741 -4.094 0.848 6.605 {"comment": "BBBS"}

[ link ]
resname $protein_resnames
[ dihedrals ]
SC1 BB +BB ++BB 3  1.204 1.857 -0.762 -0.977 1.827 0.301 {"comment": "SBBB"}

;;;ANGLE
[ link ]
resname $protein_resnames
[ angles ]
-BB BB +BB 1 132.3 23.48 {"comment": "BBB"}

[ link ]
resname $protein_resnames
[ angles ]
SC1 BB +BB 1 140.8 18.87 {"comment": "SBB"}

