;;;HSDp; peptoid residue original histidine (delta-N protonated)

[ moleculetype ]
; molname       nrexcl
   HSDp           3

[ atoms ]
;id type resnr residu atom cgnr   charge
1   $prot_default_bb_type     1     HSDp    BB     1      0    
2   TC4                       1     HSDp     SC1    2    0    ; three side chains in triangle
3   TN6d                      1     HSDp     SC2    3    0    ; configuration, mimicking
4   TN5a                      1     HSDp     SC3    4    0    ; ring structure

[ bonds ]
;  i     j   funct   length  force.c.
  BB   SC1    1       0.305     4746.30 
;  i     j   funct   length  
 SC1   SC2    1       0.320  $stiff_fc
 SC1   SC3    1       0.300  $stiff_fc 
 SC2   SC3    1       0.270  $stiff_fc
 
 [ constraints ]
;  i     j   funct   length  
 SC1   SC2    1       0.300
 SC1   SC3    1       0.320  
 SC2   SC3    1       0.270

[angles]
;  i     j    k     funct   angle  force.c.
   BB   SC1  SC2       2   120.000   50.0  
   BB   SC1  SC3       2   120.000   50.0 
   
[exclusions]
; We do not want non-bounded interactions within the residue.
BB SC1 SC2 SC3
SC1 SC2 SC3
SC2 SC3


;;;PHEp; peptoid residue original histidine (delta-N protonated)

[ moleculetype ]
; molname       nrexcl
